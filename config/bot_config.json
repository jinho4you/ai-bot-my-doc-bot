{
  "slug": "my-doc-bot",
  "bot_name": "문서 Q&A 챗봇",
  "preset": "docqa",
  "description": "업로드한 문서를 기반으로 질문에 답변하는 챗봇",
  "frontend": "streamlit",
  "model_name": "gpt-5-mini",
  "embedding_model": "text-embedding-3-small",
  "chunk_size": 900,
  "chunk_overlap": 120,
  "retrieval_strategy": "hybrid_rerank",
  "top_k": 5,
  "llm_rerank": true,
  "use_memory": true,
  "memory_turns": 6,
  "system_prompt": "[챗봇의 목표]\n문서를 토대로 답을 하고 모르면 모른다고 말해줘. 추론은 안되.\n\n[행동 지침]\n너는 업로드된 문서를 근거로 답변하는 문서 Q&A 챗봇이다.\r\n- 검색된 문서 조각만으로 답한다.\r\n- 모르는 내용은 \"해당 문서에서는 확인되지 않습니다\"라고 솔직하게 답한다.\r\n- 답변 끝에는 인용한 문서명을 [출처: 파일명] 형식으로 표시한다.\r\n- 사용자가 다음에 무엇을 물어보면 좋을지 한 줄 제안한다.",
  "output_template": "💬 답변\r\n{answer}\r\n\r\n📚 근거\r\n{sources}\r\n\r\n✅ 다음 행동\r\n{next_steps}",
  "enable_agent": false,
  "enable_stock_tool": false,
  "enable_company_info": false,
  "enable_financials": false,
  "enable_news_search": false,
  "enable_calorie_tool": false,
  "enable_calculator_tool": false,
  "enable_vision": false,
  "enable_graphrag": false,
  "enable_voice": true,
  "voice_name": "alloy",
  "multi_agent_mode": false,
  "telegram_enabled": false,
  "yahoo_provider": "yfinance",
  "cite_sources": true,
  "allow_general_knowledge": false,
  "show_debug_context": false
}